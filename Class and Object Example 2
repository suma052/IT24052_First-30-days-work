class Student {
    String name;
    int age;
    double grade;

    Student(String name, int age, double grade) {
        this.name  = name;
        this.age   = age;
        this.grade = grade;
    }

    void displayInfo() {
        System.out.println("Name:  " + name);
        System.out.println("Age:   " + age);
        System.out.println("Grade: " + grade);
    }
}

public class Main {
    public static void main(String[] args) {
        Student s1 = new Student("Raiyyan", 22, 3.6);
        Student s2 = new Student("Sadiya",   22, 3.9);

        s1.displayInfo();
        System.out.println("---");
        s2.displayInfo();
    }
}
